{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Restore presenton (192.168.3.142 proxy)",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/restore-presenton-from-remote.sh"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PRESENTON_PROXY": "socks5h://192.168.3.142:10808"
        }
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
