# ============================================
# AI PPT 统一部署环境变量配置
# 复制为 .env 并根据实际情况修改
# ============================================

# ============================================
# 基础配置
# ============================================
TZ=Asia/Shanghai

# ============================================
# Presenton 配置
# ============================================
# Presenton 对外端口
PRESENTON_PORT=5000

# LLM 配置 (至少配置一个)
LLM=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
ANTHROPIC_MODEL=ark-code-latest

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GOOGLE_API_KEY=
GOOGLE_MODEL=

# 本地 Ollama (可选)
OLLAMA_URL=
OLLAMA_MODEL=qwen2.5:7b

CUSTOM_LLM_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_MODEL=

# 其他功能配置
CAN_CHANGE_KEYS=
CODEX_MODEL=
PEXELS_API_KEY=
EXTENDED_REASONING=
TOOL_CALLS=
DISABLE_THINKING=
WEB_GROUNDING=
DISABLE_ANONYMOUS_TRACKING=1
COMFYUI_URL=
COMFYUI_WORKFLOW=

# Presenton 公网导出地址 (MCP 模式使用，一般可留空)
PRESENTON_PUBLIC_EXPORT_BASE=

# ============================================
# PPT LangGraph 配置
# ============================================
# Presenton 公网地址 (Python 后端用于将内网地址替换为公网地址)
# 见 peip_inference_interface/docs/PRESENTON_DEPLOYMENT_GUIDE.md §URL 自动替换机制
PRESENTON_PUBLIC_BASE_URL=https://ppt.installall.cn

# Python 镜像源 (国内加速)
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
TORCH_EXTRA_INDEX=https://mirrors.aliyun.com/pytorch-wheels/cpu

# ============================================
# PPT LangGraph 配置
# ============================================
# PPT 推理引擎对外端口
PPT_LANGGRAPH_PORT=8000

# LLM 模式: deterministic (纯模板) | anthropic | openai-compatible
REASONING_PPT_LLM=anthropic

# 启用的 Agent (全部启用可获得最佳效果)
PPT_LLM_AGENT_ALLOWLIST=orchestrator,template_selector,outline_planner,data,material_selector,quality_reviewer

# 通义千问 (阿里)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_MODEL=qwen3.5-plus

# 豆包 (字节)
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2.0-code

# 模型降级路由
OPENCLAW_LLM_PRIMARY=anthropic/ark-code-latest
OPENCLAW_LLM_FALLBACKS=qwen/qwen3.5-plus,doubao/doubao-seed-2.0-code
OPENCLAW_PPT_AGENT_MODELS=

# ============================================
# OpenClaw Gateway 配置
# ============================================
# OpenClaw 网关对外端口
OPENCLAW_GATEWAY_HOST_PORT=18789

# 安全密钥 (生产环境请修改为强随机串)
OPENCLAW_GATEWAY_TOKEN=openclaw-distributed-secret-key

# 微信自动注入 (默认启用)
OPENCLAW_GATEWAY_SEED_WEIXIN_IF_MISSING=1

# 其他 LLM Keys
DEEPSEEK_API_KEY=
QWEN_API_KEY=
