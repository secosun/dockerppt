# ============================================
# AI PPT 统一部署环境变量配置
# 复制为 .env 并根据实际情况修改
# ============================================

# ============================================
# 基础配置
# ============================================
TZ=Asia/Shanghai

# ============================================
# Presenton 配置
# ============================================
# Presenton 对外端口
PRESENTON_PORT=5000

# LLM 配置 (至少配置一个)
LLM=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
ANTHROPIC_MODEL=ark-code-latest

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GOOGLE_API_KEY=
GOOGLE_MODEL=

# Ollama 不在本机时填「跑 Ollama 的机器」IP:端口（Presenton 选 LLM=ollama 时用 OLLAMA_URL）
OLLAMA_URL=http://192.168.3.142:11450
OLLAMA_MODEL=qwen2.5:7b

CUSTOM_LLM_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_MODEL=

# 其他功能配置
CAN_CHANGE_KEYS=
CODEX_MODEL=
PEXELS_API_KEY=
EXTENDED_REASONING=
TOOL_CALLS=
DISABLE_THINKING=
WEB_GROUNDING=
DISABLE_ANONYMOUS_TRACKING=1
COMFYUI_URL=
COMFYUI_WORKFLOW=

# Presenton 公网导出地址 (MCP 模式使用，一般可留空)
PRESENTON_PUBLIC_EXPORT_BASE=

# ============================================
# PPT LangGraph 配置
# ============================================
# Presenton 公网地址 (Python 后端用于将内网地址替换为公网地址)
# 见 peip_inference_interface/docs/PRESENTON_DEPLOYMENT_GUIDE.md §URL 自动替换机制
PRESENTON_PUBLIC_BASE_URL=https://ppt.installall.cn

# Python 镜像源 (国内加速)
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
TORCH_EXTRA_INDEX=https://mirrors.aliyun.com/pytorch-wheels/cpu

# ============================================
# PPT LangGraph 配置
# ============================================
# PPT 推理引擎对外端口
PPT_LANGGRAPH_PORT=8000

# LangGraph 服务对外的公网 Origin（无尾斜杠），用于把产物 file:///app/outputs/... 转为可分享链接：
#   {PPT_OUTPUTS_PUBLIC_BASE_URL}/outputs/ppt/storage/<task>.pptx
# 须与 Nginx/反代到本机 8000（或映射端口）的 HTTPS 域名一致；与 PRESENTON_PUBLIC_BASE_URL 可以不同。
# 也可改用 LANGGRAPH_PUBLIC_BASE_URL / PPT_LANGGRAPH_PUBLIC_BASE_URL（代码里等价备选）。
PPT_OUTPUTS_PUBLIC_BASE_URL=

# PPT 推理 LLM：默认本地 Ollama（千问，见 OLLAMA_*）；可改回火山 Ark。
# 模式: deterministic | ollama | openclaw | anthropic | openai-compatible
REASONING_PPT_LLM=ollama
# LangGraph / Worker 访问 Ollama（与 OLLAMA_URL 通常同一台机，按需改 IP）
OLLAMA_BASE_URL=http://192.168.3.142:11450
OLLAMA_MODEL=qwen2.5:7b
#
# —— 可选：改回火山 Ark ——
# REASONING_PPT_LLM=anthropic
# （并配置上方 LLM=anthropic 与 ANTHROPIC_*）
#
# —— 可选：openclaw/anthropic 主线路时，仅部分 Agent 走 Ollama ——
# OPENCLAW_PPT_AGENT_MODELS=data=ollama-local/qwen2.5:7b,material_selector=ollama-local/qwen2.5:7b

# Presenton 单页 JSON Schema 失败时自动修补并重提整稿次数上限（默认 12）
# PRESENTON_SLIDE_SCHEMA_REPAIR_MAX=12

# 启用的 Agent (全部启用可获得最佳效果)
PPT_LLM_AGENT_ALLOWLIST=orchestrator,template_selector,outline_planner,data,material_selector,quality_reviewer

# 通义千问 (阿里)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_MODEL=qwen3.5-plus

# 豆包 (字节)
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2.0-code

# 模型降级路由
OPENCLAW_LLM_PRIMARY=anthropic/ark-code-latest
OPENCLAW_LLM_FALLBACKS=qwen/qwen3.5-plus,doubao/doubao-seed-2.0-code
OPENCLAW_PPT_AGENT_MODELS=

# ============================================
# OpenClaw Gateway 配置
# ============================================
# OpenClaw 网关对外端口
OPENCLAW_GATEWAY_HOST_PORT=18789

# 安全密钥 (生产环境请修改为强随机串)
OPENCLAW_GATEWAY_TOKEN=openclaw-distributed-secret-key

# 微信自动注入 (默认启用)
OPENCLAW_GATEWAY_SEED_WEIXIN_IF_MISSING=1

# 其他 LLM Keys
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# ============================================
# 开发机 Git 推送代理（仅主机 shell，勿依赖 compose 注入）
# ============================================
# SOCKS 在 192.168.3.142:10808（本环境常用）:
#   export ALL_PROXY=socks5h://192.168.3.142:10808
# 若 SOCKS 在本机同端口: ALL_PROXY=socks5h://127.0.0.1:10808
# 然后: ./scripts/git-deploy.sh
